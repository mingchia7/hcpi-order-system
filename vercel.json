{
  "rewrites": [
    { "source": "/operator-report.html", "destination": "/operator-report.html" },
    { "source": "/", "destination": "/hcpi-order-tracker.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    }
  ]
}
